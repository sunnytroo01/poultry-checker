<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CluckMD - Poultry Symptom Checker</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/style.css">
</head>
<body>

  <!-- ===== Bird Type Selector ===== -->
  <div id="bird-modal" class="modal-overlay">
    <div class="modal-box">
      <div class="modal-logo">
        <i class="fa-solid fa-heart-pulse"></i>
        <h1>CluckMD</h1>
      </div>
      <p class="modal-subtitle">Poultry Symptom Checker</p>
      <hr>
      <p class="modal-prompt">Select your bird type to begin:</p>
      <div class="bird-choices">
        <button class="bird-choice" data-bird="hen">
          <i class="fa-solid fa-crow"></i>
          <span>Hen</span>
        </button>
        <button class="bird-choice" data-bird="rooster">
          <i class="fa-solid fa-crow"></i>
          <span>Rooster</span>
        </button>
        <button class="bird-choice" data-bird="chick">
          <i class="fa-solid fa-kiwi-bird"></i>
          <span>Chick</span>
        </button>
      </div>
      <p class="modal-disclaimer">For educational purposes only. Consult a veterinarian for diagnosis.</p>
    </div>
  </div>

  <!-- ===== Main Application ===== -->
  <div id="app" class="app hidden">

    <!-- Top Bar -->
    <div class="topbar">
      <div class="topbar-left">
        <i class="fa-solid fa-heart-pulse logo-icon"></i>
        <strong class="logo-text">CluckMD</strong>
        <span class="topbar-sep">|</span>
        <span class="topbar-label">Symptom Checker</span>
        <span id="bird-tag" class="bird-tag"></span>
      </div>
      <button id="restart-btn" class="restart-btn">
        <i class="fa-solid fa-rotate-left"></i> Start Over
      </button>
    </div>

    <!-- 4-Column Layout -->
    <div class="columns">

      <!-- Col 1: Body Area Filter -->
      <div class="col col-areas">
        <div class="col-header">
          <i class="fa-solid fa-hand-pointer"></i> Filter by Area
        </div>
        <div class="area-list">
          <% bodyAreas.forEach(area => { %>
            <button class="area-btn<%= area.id === 'all' ? ' active' : '' %>" data-area="<%= area.id %>">
              <%= area.label %>
            </button>
          <% }) %>
        </div>
      </div>

      <!-- Col 2: Symptom List -->
      <div class="col col-symptoms">
        <div class="col-header">
          <i class="fa-solid fa-list"></i> Symptoms
          <span class="sort-controls">
            <button class="sort-btn active" data-sort="alpha">A-Z</button>
          </span>
        </div>
        <div class="search-box">
          <i class="fa-solid fa-magnifying-glass"></i>
          <input type="text" id="symptom-search" placeholder="Search symptoms...">
        </div>
        <div id="symptom-list" class="symptom-list">
          <% symptoms.forEach(s => { %>
            <button class="sym-btn" data-id="<%= s.id %>" data-area="<%= s.bodyArea %>" data-birds="<%= s.birds.join(',') %>">
              <i class="fa-solid fa-plus"></i>
              <span><%= s.label %></span>
            </button>
          <% }) %>
        </div>
      </div>

      <!-- Col 3: Selected Symptoms -->
      <div class="col col-selected">
        <div class="col-header">
          <i class="fa-solid fa-clipboard-list"></i> Selected
          <span id="sel-count" class="count-pill">0</span>
        </div>
        <div id="selected-list" class="selected-list">
          <p class="placeholder-text">
            <i class="fa-solid fa-arrow-left"></i>
            Click symptoms to add them
          </p>
        </div>
        <div class="selected-actions hidden" id="selected-actions">
          <button id="check-btn" class="check-btn">
            <i class="fa-solid fa-stethoscope"></i> Find Conditions
          </button>
          <button id="clear-btn" class="clear-btn">Clear All</button>
        </div>
      </div>

      <!-- Col 4: Possible Conditions -->
      <div class="col col-results">
        <div class="col-header">
          <i class="fa-solid fa-book-medical"></i> Possible Conditions
        </div>
        <div id="results-list" class="results-list">
          <p class="placeholder-text">
            Select symptoms and press<br>"Find Conditions" to see matches
          </p>
        </div>
      </div>

    </div>

    <!-- Footer -->
    <div class="app-footer">
      <i class="fa-solid fa-triangle-exclamation"></i>
      CluckMD is for educational reference only. Always consult a qualified avian veterinarian for proper diagnosis and treatment.
    </div>
  </div>

  <script>
    let birdType = null;
    const selected = new Set();

    // ── Bird selection ──
    document.querySelectorAll(".bird-choice").forEach(btn => {
      btn.addEventListener("click", () => {
        birdType = btn.dataset.bird;
        document.getElementById("bird-modal").classList.add("hidden");
        document.getElementById("app").classList.remove("hidden");
        document.getElementById("bird-tag").textContent = btn.querySelector("span").textContent;

        // Hide symptoms not for this bird type
        document.querySelectorAll(".sym-btn").forEach(sb => {
          const birds = sb.dataset.birds.split(",");
          if (!birds.includes(birdType)) {
            sb.classList.add("hidden");
          }
        });
      });
    });

    // ── Start over ──
    document.getElementById("restart-btn").addEventListener("click", () => {
      birdType = null;
      selected.clear();
      document.getElementById("bird-modal").classList.remove("hidden");
      document.getElementById("app").classList.add("hidden");
      document.querySelectorAll(".sym-btn").forEach(b => {
        b.classList.remove("hidden", "picked");
        b.disabled = false;
      });
      document.querySelectorAll(".area-btn").forEach(b => b.classList.remove("active"));
      document.querySelector('.area-btn[data-area="all"]').classList.add("active");
      document.getElementById("symptom-search").value = "";
      refreshSelected();
      document.getElementById("results-list").innerHTML =
        '<p class="placeholder-text">Select symptoms and press<br>"Find Conditions" to see matches</p>';
    });

    // ── Body area filter ──
    document.querySelectorAll(".area-btn").forEach(btn => {
      btn.addEventListener("click", () => {
        document.querySelectorAll(".area-btn").forEach(b => b.classList.remove("active"));
        btn.classList.add("active");
        const area = btn.dataset.area;
        document.querySelectorAll(".sym-btn").forEach(sb => {
          const birds = sb.dataset.birds.split(",");
          const birdOk = birds.includes(birdType);
          const areaOk = area === "all" || sb.dataset.area === area;
          const searchOk = matchesSearch(sb);
          if (birdOk && areaOk && searchOk) {
            sb.classList.remove("hidden");
          } else {
            sb.classList.add("hidden");
          }
        });
      });
    });

    // ── Search ──
    function matchesSearch(btn) {
      const q = document.getElementById("symptom-search").value.toLowerCase().trim();
      if (!q) return true;
      return btn.querySelector("span").textContent.toLowerCase().includes(q);
    }

    document.getElementById("symptom-search").addEventListener("input", () => {
      const activeArea = document.querySelector(".area-btn.active").dataset.area;
      document.querySelectorAll(".sym-btn").forEach(sb => {
        const birds = sb.dataset.birds.split(",");
        const birdOk = birds.includes(birdType);
        const areaOk = activeArea === "all" || sb.dataset.area === activeArea;
        const searchOk = matchesSearch(sb);
        if (birdOk && areaOk && searchOk) {
          sb.classList.remove("hidden");
        } else {
          sb.classList.add("hidden");
        }
      });
    });

    // ── Add symptom ──
    document.querySelectorAll(".sym-btn").forEach(btn => {
      btn.addEventListener("click", () => {
        if (selected.has(btn.dataset.id)) return;
        selected.add(btn.dataset.id);
        btn.classList.add("picked");
        btn.disabled = true;
        refreshSelected();
        autoCheck();
      });
    });

    // ── Refresh selected panel ──
    function refreshSelected() {
      const list = document.getElementById("selected-list");
      const count = document.getElementById("sel-count");
      const actions = document.getElementById("selected-actions");

      count.textContent = selected.size;

      if (selected.size === 0) {
        list.innerHTML = '<p class="placeholder-text"><i class="fa-solid fa-arrow-left"></i> Click symptoms to add them</p>';
        actions.classList.add("hidden");
        return;
      }

      actions.classList.remove("hidden");
      list.innerHTML = "";

      selected.forEach(id => {
        const src = document.querySelector(`.sym-btn[data-id="${id}"]`);
        const label = src.querySelector("span").textContent;
        const tag = document.createElement("div");
        tag.className = "sel-tag";
        tag.innerHTML = `<span>${label}</span><button class="rem-btn" data-id="${id}"><i class="fa-solid fa-xmark"></i></button>`;
        list.appendChild(tag);
      });

      list.querySelectorAll(".rem-btn").forEach(btn => {
        btn.addEventListener("click", () => {
          selected.delete(btn.dataset.id);
          const src = document.querySelector(`.sym-btn[data-id="${btn.dataset.id}"]`);
          src.classList.remove("picked");
          src.disabled = false;
          refreshSelected();
          autoCheck();
        });
      });
    }

    // ── Auto-check as symptoms change ──
    function autoCheck() {
      if (selected.size >= 2) {
        runCheck();
      } else if (selected.size === 0) {
        document.getElementById("results-list").innerHTML =
          '<p class="placeholder-text">Select symptoms and press<br>"Find Conditions" to see matches</p>';
      } else {
        document.getElementById("results-list").innerHTML =
          '<p class="placeholder-text">Select at least 2 symptoms to find matching conditions</p>';
      }
    }

    // ── Manual check button ──
    document.getElementById("check-btn").addEventListener("click", runCheck);

    // ── Clear all ──
    document.getElementById("clear-btn").addEventListener("click", () => {
      selected.clear();
      document.querySelectorAll(".sym-btn").forEach(b => {
        b.classList.remove("picked");
        b.disabled = false;
      });
      refreshSelected();
      document.getElementById("results-list").innerHTML =
        '<p class="placeholder-text">Select symptoms and press<br>"Find Conditions" to see matches</p>';
    });

    // ── Run the check ──
    async function runCheck() {
      if (selected.size < 2) return;

      const res = await fetch("/check", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ symptoms: Array.from(selected), birdType }),
      });
      const data = await res.json();
      const container = document.getElementById("results-list");

      if (data.results.length === 0) {
        container.innerHTML = `
          <div class="no-match">
            <i class="fa-solid fa-circle-question"></i>
            <p>No conditions matched your selected symptoms.</p>
            <p class="hint">Try adding more symptoms or different combinations.</p>
          </div>`;
        return;
      }

      container.innerHTML = "";
      data.results.forEach(c => {
        const card = document.createElement("div");
        card.className = "condition-card";
        const catClass = c.category.toLowerCase().replace(/[^a-z]/g, "");
        card.innerHTML = `
          <div class="cond-top">
            <h3 class="cond-name">${c.name}</h3>
            <span class="cat-label cat-${catClass}">${c.category}</span>
          </div>
          <div class="match-bar-wrap">
            <div class="match-bar" style="width: ${c.percentage}%"></div>
            <span class="match-pct">${c.percentage}% match (${c.matchedCount}/${c.totalSymptoms} symptoms)</span>
          </div>
          <p class="cond-desc">${c.description}</p>
          <div class="cond-matched">
            <strong>Matching symptoms:</strong>
            ${c.matchedLabels.map(l => `<span class="matched-tag">${l}</span>`).join("")}
          </div>
        `;
        container.appendChild(card);
      });
    }
  </script>
</body>
</html>
